<?xml version="1.0" encoding="utf-8" ?>
<odoo>

    <!-- Completely redesign login page: WeChat primary, admin login collapsed -->
    <template id="login_wechat" inherit_id="web.login" name="Custom Login Page" priority="20">

        <!-- Remove owl user_switch component -->
        <xpath expr="//owl-component[@name='web.user_switch']" position="replace"/>

        <!-- Add WeChat primary login section BEFORE the form -->
        <xpath expr="//form[contains(@t-attf-class, 'oe_login_form')]" position="before">
            <div id="wechat_login_section" class="text-center">
                <!-- Brand heading -->
                <h2 class="mb-4" style="color: #714B67; font-weight: bold;">
                    <i class="fa fa-language me-2"/>TS translate
                </h2>

                <!-- WeChat QR login button -->
                <a href="/auth_wechat/login"
                   class="btn btn-success btn-lg w-100 mb-3"
                   style="font-size: 1.1rem; padding: 12px;">
                    <svg class="me-2" viewBox="0 0 24 24" width="22" height="22" fill="white" style="vertical-align: text-bottom;">
                        <path d="M8.691 2.188C3.891 2.188 0 5.476 0 9.53c0 2.212 1.17 4.203 3.002 5.55a.59.59 0 0 1 .213.665l-.39 1.48c-.019.07-.048.141-.048.213 0 .163.13.295.29.295a.326.326 0 0 0 .167-.054l1.903-1.114a.864.864 0 0 1 .717-.098 10.16 10.16 0 0 0 2.837.403c.276 0 .543-.027.811-.05-.857-2.578.157-4.972 1.932-6.446 1.703-1.415 3.882-1.98 5.853-1.838-.576-3.583-4.196-6.348-8.596-6.348zM5.785 5.991c.642 0 1.162.529 1.162 1.18a1.17 1.17 0 0 1-1.162 1.178A1.17 1.17 0 0 1 4.623 7.17c0-.651.52-1.18 1.162-1.18zm5.813 0c.642 0 1.162.529 1.162 1.18a1.17 1.17 0 0 1-1.162 1.178 1.17 1.17 0 0 1-1.162-1.178c0-.651.52-1.18 1.162-1.18zm5.34 2.867c-1.797-.052-3.746.512-5.28 1.786-1.72 1.428-2.687 3.72-1.78 6.22.942 2.453 3.666 4.229 6.884 4.229.826 0 1.622-.12 2.361-.336a.722.722 0 0 1 .598.082l1.584.926a.272.272 0 0 0 .14.045c.134 0 .24-.11.24-.245 0-.06-.024-.12-.04-.178l-.325-1.233a.49.49 0 0 1 .177-.554C23.242 18.547 24 17.07 24 15.44c0-3.291-3.066-6.131-7.062-6.582zm-2.089 2.86c.535 0 .969.44.969.982a.976.976 0 0 1-.969.983.976.976 0 0 1-.969-.983c0-.542.434-.982.97-.982zm4.844 0c.535 0 .969.44.969.982a.976.976 0 0 1-.969.983.976.976 0 0 1-.969-.983c0-.542.434-.982.97-.982z"/>
                    </svg>
                    微信扫码登录
                </a>

                <!-- Admin login toggle -->
                <div class="my-3">
                    <div class="d-flex align-items-center mb-2">
                        <hr class="flex-grow-1"/>
                        <span class="mx-2 text-muted small">或</span>
                        <hr class="flex-grow-1"/>
                    </div>
                    <a href="javascript:void(0)" id="toggle_admin_login"
                       class="text-muted" style="font-size: 0.85rem; text-decoration: none;">
                        用户名密码登录 ▸
                    </a>
                </div>
            </div>
        </xpath>

        <!-- Hide the standard form by default and give it an id for JS toggle -->
        <xpath expr="//form[contains(@t-attf-class, 'oe_login_form')]" position="attributes">
            <attribute name="t-attf-class">oe_login_form d-none</attribute>
            <attribute name="id">admin_login_form</attribute>
        </xpath>

        <!-- Remove Odoo OAuth login section ("- or -" + Odoo official login button) -->
        <xpath expr="//div[hasclass('o_login_auth')]" position="replace">
            <div class="o_login_auth d-none"/>
        </xpath>

    </template>





    <!-- Script to handle admin login toggle and auto-show on errors -->
    <template id="login_wechat_script" inherit_id="web.login_layout" name="Login Toggle Script" priority="20">
        <xpath expr="//div[hasclass('card-body')]" position="inside">
            <script type="text/javascript">
                document.addEventListener("DOMContentLoaded", function() {
                    var toggleBtn = document.getElementById("toggle_admin_login");
                    var adminForm = document.getElementById("admin_login_form");
                    if (!toggleBtn || !adminForm) return;

                    // Toggle admin login form
                    toggleBtn.addEventListener("click", function() {
                        var hidden = adminForm.classList.contains("d-none");
                        adminForm.classList.toggle("d-none");
                        this.textContent = hidden ? "收起 ▾" : "用户名密码登录 ▸";
                    });

                    // Auto-show form if there's an error or a login value
                    var hasError = adminForm.querySelector(".alert-danger");
                    var loginInput = adminForm.querySelector("input[name='login']");
                    if (hasError || (loginInput &amp;&amp; loginInput.value)) {
                        adminForm.classList.remove("d-none");
                        toggleBtn.textContent = "收起 ▾";
                    }
                    
                });
            </script>
        </xpath>
    </template>

</odoo>
